<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">
    
    
    <bean id="produitDAO" class="dao.ProduitImpl" init-method="init"/>
    <bean id="userDAO" class="dao.UserImpl" init-method="init"/>
    
    
    <bean id="produitService" class="services.ProduitImplMetier">
        <property name="dao" ref="produitDAO"/>
    </bean>
    <bean id="userService" class="services.UserServiceImpl">
        <property name="userDao" ref="userDAO"/>
    </bean>
    
</beans>
